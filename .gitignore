# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징·빌드 산출물
build/
dist/
*.egg-info/
.eggs/

# ── 테스트·타입 캐시 ────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── 에디터·OS ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# 오피스 문서 잠금·임시 파일(문서를 연 동안만 생기며 커밋 대상이 아님)
.~lock.*#
~$*
*.tmp

# ── 프로젝트 산출물·데이터(재생성 가능) ─────────────────────────
# 백테스트가 생성하는 HTML 리포트(main.py 실행 시 재생성)
reports/
# yfinance OHLCV 캐시(config.cache=true 로 재다운로드 가능)
datasets/ohlcv/*.parquet
# 예외: 금 현물(ACE KRX금현물). 54KB 뿐이고, 이게 없으면 클론 직후 유니버스 무결성
# 가드가 백테스트를 막아 동결 수치를 재현할 수 없다(다른 종목과 달리 최근 추가라 팀원
# 캐시에 없다). 오프라인 즉시 재현용 보험.
!datasets/ohlcv/411060.parquet
