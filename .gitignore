# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징·빌드 산출물
build/
dist/
*.egg-info/
.eggs/

# ── 테스트·타입 캐시 ────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── 에디터·OS ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── 프로젝트 산출물·데이터(재생성 가능) ─────────────────────────
# 백테스트가 생성하는 HTML 리포트·CSV(러너 실행 시 재생성)
reports/
# 예외: 차트 PNG 는 추적한다. 제안서·발표가 직접 참조하는 확정 전시물이라, 캐시 없는
# 팀원도 클론만으로 그림을 봐야 한다. 규칙으로 두는 이유는 `git add -f` 를 잊으면
# 갱신한 그림이 조용히 빠지고 문서에는 옛 그림이 남기 때문이다.
# (디렉터리 자체가 무시되면 하위 예외가 먹지 않으므로 디렉터리를 먼저 열어 준다.)
!reports/
reports/*
!reports/*.png
# yfinance OHLCV 캐시(config.cache=true 로 재다운로드 가능)
datasets/ohlcv/*.parquet
# 예외: 금 현물(ACE KRX금현물). 54KB 뿐이고, 이게 없으면 클론 직후 유니버스 무결성
# 가드가 백테스트를 막아 동결 수치를 재현할 수 없다(다른 종목과 달리 최근 추가라 팀원
# 캐시에 없다). 오프라인 즉시 재현용 보험.
!datasets/ohlcv/411060.parquet
