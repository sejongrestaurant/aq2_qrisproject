# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징·빌드 산출물
build/
dist/
*.egg-info/
.eggs/

# ── 테스트·타입 캐시 ────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── 에디터·OS ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# 오피스 문서 잠금·임시 파일(문서를 연 동안만 생기며 커밋 대상이 아님)
.~lock.*#
~$*
*.tmp

# ── 프로젝트 산출물(재생성 가능) ───────────────────────────────
# 백테스트가 생성하는 HTML 리포트(main.py 실행 시 재생성)
reports/

# ── 남의 저장소·백업 파일(절대 커밋 금지) ──────────────────────
# 참고용으로 받아 둔 다른 조 저장소. 자체 .git 과 브로커 인증 토큰(token_*.dat)이
# 들어 있어 `git add -A` 한 번이면 남의 자격증명이 그대로 올라간다.
doc/다른조/
# 발표자료를 편집할 때 뜬 원본 백업(로컬 보관용, 재생성 불가하지만 산출물은 아님)
doc/*_원본백업_*.pptx

# ── 시세 데이터: 스냅샷 박제 ────────────────────────────────────
# datasets/ohlcv/*.parquet 는 원래 재생성 가능(yfinance)이라 무시했으나,
# 로더가 auto_adjust=True 라 배당이 소급 반영돼 **다운로드 시점에 따라 최근
# 배당락 구간(2026 후반)의 수익률이 달라진다**. 그래서 같은 코드·같은 종료일로
# 돌려도 사람마다 2026 수익률이 갈렸다(27.5 vs 29.3 논쟁). 데이터를 이 시점으로
# 박제해 팀 전체가 동일 결과를 내도록 추적 대상에 포함한다. 스냅샷 기준일은
# doc/deck/README.md 참조. 이후 갱신은 팀 합의로만 한다.
